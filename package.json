{
  "name": "notification-preference-service",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsup",
    "start": "node dist/main.js",
    "typecheck": "npm run typecheck:src && npm run typecheck:test",
    "prepare": "node .husky/install.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:docker:up": "docker compose --env-file .env.development -f compose.development.yaml up --build",
    "dev:docker:down": "docker compose --env-file .env.development -f compose.development.yaml down",
    "dev:docker:renew": "docker compose --env-file .env.development -f compose.development.yaml up --build --renew-anon-volumes",
    "prod:docker:up": "docker compose --env-file .env.production -f compose.production.yaml up --build -d",
    "prod:docker:down": "docker compose --env-file .env.production -f compose.production.yaml down",
    "prod:docker:renew": "docker compose --env-file .env.production -f compose.production.yaml up --build --renew-anon-volumes -d",
    "db:seed:test": "tsx scripts/run-seed.ts seeds/pg/test-data.seed.sql",
    "db:generate": "NODE_ENV=development drizzle-kit generate",
    "db:migrate": "NODE_ENV=development drizzle-kit migrate",
    "db:studio": "NODE_ENV=development drizzle-kit studio",
    "db:migrate:production": "NODE_ENV=production drizzle-kit migrate",
    "db:migrate:production:docker": "docker compose --env-file .env.production -f compose.production.yaml exec app npm run db:migrate",
    "db:migrate:development:docker": "docker compose --env-file .env.development -f compose.development.yaml exec app npm run db:migrate",
    "source-code:generate": "node scripts/generate-project-source.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "typecheck:src": "tsc --noEmit",
    "typecheck:test": "tsc --project tsconfig.test.json --noEmit"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,jsonc,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AveryOn/notification-preferences-service.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/AveryOn/notification-preferences-service/issues"
  },
  "homepage": "https://github.com/AveryOn/notification-preferences-service#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testcontainers/postgresql": "^12.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "testcontainers": "^12.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.4.3"
  }
}
